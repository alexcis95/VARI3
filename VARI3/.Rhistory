cboruta <-cbind(tboruta, condiciones) # Dataframe con todo
finalboruta <- cboruta[,-c(17470:17471)] # Eliminamos genero y edad para usar este df para los modelos sin edad y genero
modeloboruta <- readRDS("modeloboruta")
fd <- modeloboruta$finalDecision
dffd <- as.data.frame(fd)
dfn <- tibble::rownames_to_column(dffd)
Confirmed <- filter(dfn, dfn[1:17468,2] == "Confirmed")
Confirmed
tentativa <- TentativeRoughFix(modeloboruta)
fd <- tentativa$finalDecision
dffd <- as.data.frame(fd)
dfn <- tibble::rownames_to_column(dffd)
Confirmed2 <- filter(dfn, dfn[1:17468,2] == "Confirmed")
Confirmed2
restatus <- read.csv("Replication_Phenotype(1).txt", sep = "\t") # Status file
